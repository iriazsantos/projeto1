NODE_ENV=production
PORT=3000

# Troque por um segredo forte e unico.
JWT_SECRET=troque-por-um-jwt-secret-forte

# Mesmo dominio do app em producao.
CORS_ORIGINS=https://seudominio.com,https://www.seudominio.com

# Banco SQLite local do projeto.
DATABASE_URL=file:./prisma/dev.db

# Opcional (quando usar seed)
ADMIN_PASSWORD=troque-esta-senha
DEFAULT_USER_PASSWORD=troque-esta-senha

# Opcional (agente IA)
AGENT_ENABLED=false
# AGENT_PROVIDER=anthropic
# AGENT_API_KEY=
# AGENT_BASE_URL=https://api.anthropic.com
# AGENT_MODEL=claude-3-5-sonnet-20241022
